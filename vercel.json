{
  "version": 2,
  "name": "nvlp-app",
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "buildCommand": "pnpm build:vercel:prod",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "env": {
    "TURBO_TOKEN": "@turbo_token",
    "TURBO_TEAM": "@turbo_team"
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- packages/ apps/api/ vercel.json package.json pnpm-lock.yaml",
  "outputDirectory": "public",
  "devCommand": "pnpm dev:packages",
  "commandTimeout": 300,
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "https://qnpatlosomopoimtsmsr.supabase.co/functions/v1/:path*",
      "has": [
        {
          "type": "host",
          "value": "edge-api.nvlp.app"
        }
      ]
    },
    {
      "source": "/:path*",
      "destination": "https://qnpatlosomopoimtsmsr.supabase.co/rest/v1/:path*",
      "has": [
        {
          "type": "host",
          "value": "db-api.nvlp.app"
        }
      ]
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, apikey"
        }
      ],
      "has": [
        {
          "type": "host",
          "value": "edge-api.nvlp.app"
        }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, apikey"
        }
      ],
      "has": [
        {
          "type": "host",
          "value": "db-api.nvlp.app"
        }
      ]
    }
  ]
}