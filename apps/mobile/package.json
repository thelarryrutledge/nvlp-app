{
  "name": "@nvlp/mobile",
  "version": "0.0.1",
  "private": true,
  "description": "NVLP Mobile App - React Native application for Virtual Envelope Budget management",
  "main": "index.js",
  "scripts": {
    "android": "PATH=/opt/homebrew/bin:$PATH react-native run-android --no-packager",
    "ios": "PATH=/opt/homebrew/bin:$PATH react-native run-ios --no-packager",
    "dev": "./scripts/start-metro.sh",
    "start": "./scripts/start-metro.sh",
    "start:reset": "./scripts/start-metro.sh --reset-cache",
    "devtools": "PATH=/opt/homebrew/bin:$PATH react-devtools",
    "ios:dev": "concurrently \"npm run start\" \"npm run ios\"",
    "android:dev": "concurrently \"npm run start\" \"npm run android\"",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "code-quality": "npm run type-check && npm run lint && npm run format:check",
    "clean": "rm -rf node_modules && rm -rf ios/Pods && rm -rf android/build && rm -rf android/app/build",
    "pod-install": "cd ios && pod install",
    "reset-cache": "npx react-native start --reset-cache",
    "build": "echo 'Use platform-specific build commands: build:ios or build:android'",
    "build:ios": "cd ios && xcodebuild -workspace NVLPMobile.xcworkspace -scheme NVLPMobile -configuration Release -archivePath ./build/NVLPMobile.xcarchive archive",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && ./gradlew bundleRelease",
    "build:ios:prod": "NODE_ENV=production ./ios/scripts/sync-version.sh && cd ios && xcodebuild -workspace NVLPMobile.xcworkspace -scheme NVLPMobile -configuration Release -archivePath ./build/Release/NVLPMobile.xcarchive archive",
    "build:android:prod": "NODE_ENV=production cd android && ./gradlew bundleRelease -PversionName=$(node -p \"require('./package.json').version\")",
    "build:analyze": "npx react-native-bundle-visualizer",
    "build:validate:ios": "./ios/scripts/build-config.sh",
    "prebuild:ios": "./ios/scripts/sync-version.sh",
    "prebuild:ios:prod": "./ios/scripts/sync-version.sh && pnpm typecheck && pnpm lint",
    "prebuild:android:prod": "pnpm typecheck && pnpm lint"
  },
  "dependencies": {
    "@babel/runtime": "^7.27.6",
    "@nvlp/client": "workspace:*",
    "@nvlp/config": "workspace:*",
    "@nvlp/types": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native/new-app-screen": "0.80.1",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "@react-navigation/drawer": "^7.5.3",
    "@react-navigation/native": "^7.1.14",
    "@react-navigation/native-stack": "^7.3.21",
    "date-fns": "^4.1.0",
    "react": "19.1.0",
    "react-native": "0.80.1",
    "react-native-config": "^1.5.5",
    "react-native-gesture-handler": "^2.27.1",
    "react-native-reanimated": "^3.18.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-vector-icons": "^10.2.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@react-native-community/cli": "19.0.0",
    "@react-native-community/cli-platform-android": "19.0.0",
    "@react-native-community/cli-platform-ios": "19.0.0",
    "@react-native/babel-preset": "0.80.1",
    "@react-native/codegen": "^0.80.1",
    "@react-native/eslint-config": "0.80.1",
    "@react-native/metro-config": "^0.80.1",
    "@react-native/typescript-config": "0.80.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.7.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^9.2.0",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.6.3",
    "prettier": "^3.3.2",
    "react-devtools": "^6.1.5",
    "react-test-renderer": "19.1.0",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thelarryrutledge/nvlp-app.git",
    "directory": "apps/mobile"
  },
  "bugs": {
    "url": "https://github.com/thelarryrutledge/nvlp-app/issues"
  },
  "homepage": "https://github.com/thelarryrutledge/nvlp-app/tree/main/apps/mobile#readme",
  "keywords": [
    "nvlp",
    "budget",
    "finance",
    "mobile",
    "react-native",
    "envelope-budgeting"
  ],
  "author": "NVLP Team",
  "license": "ISC"
}