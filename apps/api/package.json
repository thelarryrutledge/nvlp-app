{
  "name": "@nvlp/api",
  "version": "1.0.0",
  "private": true,
  "description": "NVLP API - Backend services and Edge Functions",
  "main": "index.js",
  "scripts": {
    "dev": "vercel dev --listen 3001",
    "build": "tsc",
    "deploy": "vercel --prod",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .vercel",
    "test": "echo \"No tests for API yet\""
  },
  "dependencies": {
    "@nvlp/client": "workspace:*",
    "@nvlp/types": "workspace:*",
    "dotenv": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/node": "^3.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vercel": "^32.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}