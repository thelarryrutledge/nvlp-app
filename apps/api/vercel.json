{
  "_comment": "This configuration is for documentation only",
  "_note": "NVLP API uses Supabase Edge Functions, not Vercel functions",
  "deployment": {
    "type": "supabase",
    "commands": {
      "dev": "supabase start && supabase functions serve",
      "deploy": "supabase functions deploy",
      "deploy_individual": {
        "auth": "supabase functions deploy auth",
        "dashboard": "supabase functions deploy dashboard", 
        "transactions": "supabase functions deploy transactions",
        "reports": "supabase functions deploy reports",
        "audit": "supabase functions deploy audit",
        "export": "supabase functions deploy export",
        "health": "supabase functions deploy health",
        "notifications": "supabase functions deploy notifications"
      }
    }
  },
  "environment_variables": {
    "required": [
      "SUPABASE_URL",
      "SUPABASE_ANON_KEY", 
      "SUPABASE_SERVICE_KEY",
      "JWT_SECRET"
    ],
    "optional": [
      "DB_API_URL",
      "EDGE_API_URL",
      "CORS_ORIGIN",
      "LOG_LEVEL"
    ]
  },
  "endpoints": {
    "base_url": "https://qnpatlosomopoimtsmsr.supabase.co/functions/v1",
    "functions": [
      "/auth",
      "/dashboard", 
      "/transactions",
      "/reports",
      "/audit",
      "/export",
      "/health",
      "/notifications"
    ]
  }
}