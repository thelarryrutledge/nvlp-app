{
  "name": "@nvlp/root",
  "version": "1.0.0",
  "private": true,
  "description": "NVLP - Virtual Envelope Budget App Monorepo",
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thelarryrutledge/nvlp-app.git"
  },
  "bugs": {
    "url": "https://github.com/thelarryrutledge/nvlp-app/issues"
  },
  "homepage": "https://github.com/thelarryrutledge/nvlp-app#readme",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n 'packages,api-notice' -c 'cyan,green' 'pnpm dev:packages' 'echo \"🌐 API uses remote Supabase - deploy with pnpm deploy:api\"'",
    "dev:all": "concurrently -n 'packages,mobile' -c 'cyan,magenta' 'pnpm dev:packages' 'pnpm dev:mobile'",
    "dev:packages": "pnpm --parallel --filter './packages/**' dev",
    "dev:apps": "concurrently -n 'api,mobile' -c 'green,magenta' 'pnpm dev:api' 'pnpm dev:mobile'",
    "dev:full": "concurrently -n 'types,client,api,mobile' -c 'blue,yellow,green,magenta' 'pnpm --filter @nvlp/types dev' 'pnpm --filter @nvlp/client dev' 'pnpm dev:api' 'pnpm dev:mobile'",
    "dev:api": "pnpm --filter @nvlp/api dev",
    "dev:mobile": "pnpm --filter @nvlp/mobile dev",
    "dev:mobile:ios": "pnpm --filter @nvlp/mobile ios:dev",
    "dev:mobile:android": "pnpm --filter @nvlp/mobile android:dev",
    "dev:mobile:metro": "pnpm --filter @nvlp/mobile start",
    "dev:web": "pnpm --filter @nvlp/web dev",
    "dev:db": "pnpm --filter @nvlp/api dev:db",
    "dev:watch": "pnpm dev:full",
    "dev:hot": "./scripts/dev-watch.sh",
    "dev:guide": "./scripts/dev-guide.sh",
    "dev:check": "./scripts/check-dev-environment.sh",
    "test:mobile:workflow": "./scripts/test-mobile-workflow.sh",
    "demo:mobile": "./scripts/demo-mobile-workflow.sh",
    "test:api:workflow": "./scripts/test-api-workflow.sh",
    "demo:api": "./scripts/demo-api-workflow.sh",
    "test:production": "./scripts/test-production-build.sh",
    "test:dependencies": "./scripts/test-build-dependencies.sh",
    "analyze:dependencies": "./scripts/analyze-dependencies.js",
    "optimize:pipeline": "./scripts/optimize-build-pipeline.js",
    "build": "turbo run build",
    "build:prod": "NODE_ENV=production turbo run build:prod",
    "build:all": "turbo run build --filter='./apps/**' --filter='./packages/**'",
    "build:apps": "turbo run build --filter='./apps/**'",
    "build:packages": "turbo run build --filter='./packages/**'",
    "build:types": "turbo run build --filter=@nvlp/types",
    "build:client": "turbo run build --filter=@nvlp/client",
    "build:api": "pnpm --filter @nvlp/api build",
    "build:mobile": "echo 'Mobile app builds are platform-specific. Use: pnpm build:mobile:ios or pnpm build:mobile:android'",
    "build:mobile:ios": "pnpm --filter @nvlp/mobile build:ios",
    "build:mobile:android": "pnpm --filter @nvlp/mobile build:android",
    "build:mobile:ios:prod": "pnpm --filter @nvlp/mobile build:ios:prod",
    "build:mobile:android:prod": "pnpm --filter @nvlp/mobile build:android:prod",
    "build:watch": "turbo run dev --filter='./packages/**'",
    "build:analyze": "turbo run build:analyze",
    "test": "pnpm test:packages && pnpm test:apps",
    "test:all": "pnpm test:packages && pnpm test:apps",
    "test:packages": "pnpm test:types && pnpm test:client",
    "test:apps": "pnpm test:mobile && pnpm test:api",
    "test:types": "pnpm --filter @nvlp/types test",
    "test:client": "pnpm --filter @nvlp/client test",
    "test:mobile": "pnpm --filter @nvlp/mobile test || echo '⚠️  Mobile tests have React Native Jest compatibility issues'",
    "test:api": "pnpm --filter @nvlp/api test || echo '⚠️  API tests require Deno runtime'",
    "test:watch": "concurrently -n 'client,mobile' -c 'yellow,magenta' 'pnpm --filter @nvlp/client test:watch' 'pnpm --filter @nvlp/mobile test --watch'",
    "test:coverage": "echo 'Coverage available via: pnpm --filter @nvlp/client test:coverage (requires @vitest/coverage setup)'",
    "test:script": "./scripts/test-all.sh",
    "lint": "pnpm lint:packages && pnpm lint:apps",
    "lint:all": "pnpm lint:packages && pnpm lint:apps",
    "lint:packages": "pnpm lint:types && pnpm lint:client && pnpm lint:config",
    "lint:apps": "pnpm lint:mobile && pnpm lint:api",
    "lint:types": "pnpm --filter @nvlp/types lint",
    "lint:client": "pnpm --filter @nvlp/client lint",
    "lint:config": "pnpm --filter @nvlp/config lint",
    "lint:mobile": "pnpm --filter @nvlp/mobile lint || echo '⚠️  Mobile has lint issues - use lint:fix to resolve'",
    "lint:api": "command -v deno >/dev/null 2>&1 && pnpm --filter @nvlp/api lint || pnpm --filter @nvlp/api lint:eslint",
    "lint:fix": "pnpm lint:fix:packages && pnpm lint:fix:apps",
    "lint:fix:packages": "pnpm --filter './packages/**' lint:fix",
    "lint:fix:apps": "pnpm --filter './apps/**' lint:fix",
    "lint:script": "./scripts/lint-all.sh",
    "format": "pnpm run -r format",
    "format:check": "pnpm run -r format:check",
    "clean": "pnpm clean:packages && pnpm clean:apps",
    "clean:all": "pnpm clean:packages && pnpm clean:apps && pnpm clean:root",
    "clean:packages": "pnpm clean:types && pnpm clean:client && pnpm clean:config",
    "clean:apps": "pnpm clean:mobile && pnpm clean:api",
    "clean:types": "pnpm --filter @nvlp/types clean",
    "clean:client": "pnpm --filter @nvlp/client clean",
    "clean:config": "pnpm --filter @nvlp/config clean",
    "clean:mobile": "pnpm --filter @nvlp/mobile clean",
    "clean:api": "pnpm --filter @nvlp/api clean",
    "clean:root": "rm -rf node_modules .turbo coverage .cache",
    "clean:deep": "pnpm clean:all && rm -rf apps/*/node_modules packages/*/node_modules && pnpm install",
    "clean:reset": "pnpm clean:deep && pnpm build",
    "clean:script": "./scripts/clean-all.sh",
    "typecheck": "pnpm run -r typecheck",
    "install:all": "pnpm install",
    "update:deps": "pnpm update -r",
    "verify": "pnpm run build && pnpm run test && pnpm run lint",
    "deploy:api": "pnpm --filter @nvlp/api deploy",
    "deploy:api:auth": "pnpm --filter @nvlp/api deploy:auth",
    "deploy:api:dashboard": "pnpm --filter @nvlp/api deploy:dashboard",
    "deploy:api:transactions": "pnpm --filter @nvlp/api deploy:transactions",
    "deploy:api:reports": "pnpm --filter @nvlp/api deploy:reports",
    "db:reset": "pnpm --filter @nvlp/api db:reset",
    "db:migrate": "pnpm --filter @nvlp/api db:migrate",
    "db:types": "pnpm --filter @nvlp/api db:types",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build:prod && changeset publish",
    "prepare": "pnpm run build:packages",
    "validate:env": "node ./scripts/validate-env.js",
    "build:production": "./scripts/build-prod.sh",
    "build:production:packages": "./scripts/build-prod.sh --target packages",
    "build:production:mobile": "./scripts/build-prod.sh --target mobile",
    "build:production:api": "./scripts/build-prod.sh --target api",
    "prebuild:prod": "pnpm validate:env"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.13.1"
}