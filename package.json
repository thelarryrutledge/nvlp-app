{
  "name": "@nvlp/root",
  "version": "1.0.0",
  "private": true,
  "description": "NVLP - Virtual Envelope Budget App Monorepo",
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thelarryrutledge/nvlp-app.git"
  },
  "bugs": {
    "url": "https://github.com/thelarryrutledge/nvlp-app/issues"
  },
  "homepage": "https://github.com/thelarryrutledge/nvlp-app#readme",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n 'packages,api' -c 'cyan,green' 'pnpm dev:packages' 'pnpm dev:api'",
    "dev:all": "concurrently -n 'packages,api,mobile' -c 'cyan,green,magenta' 'pnpm dev:packages' 'pnpm dev:api' 'pnpm dev:mobile:metro'",
    "dev:packages": "pnpm --parallel --filter './packages/**' dev",
    "dev:api": "pnpm --filter @nvlp/api dev",
    "dev:mobile": "echo 'Choose platform: pnpm dev:mobile:ios or pnpm dev:mobile:android'",
    "dev:mobile:ios": "pnpm --filter @nvlp/mobile ios:dev",
    "dev:mobile:android": "pnpm --filter @nvlp/mobile android:dev",
    "dev:mobile:metro": "pnpm --filter @nvlp/mobile start",
    "dev:web": "pnpm --filter @nvlp/web dev",
    "dev:db": "pnpm --filter @nvlp/api dev:db",
    "build": "pnpm build:packages && echo '✅ All packages built successfully!'",
    "build:all": "pnpm build:packages && pnpm build:apps",
    "build:apps": "pnpm --filter './apps/**' build",
    "build:packages": "pnpm build:types && pnpm build:client",
    "build:types": "pnpm --filter @nvlp/types build",
    "build:client": "pnpm --filter @nvlp/client build",
    "build:api": "pnpm --filter @nvlp/api build",
    "build:mobile": "echo 'Mobile app builds are platform-specific. Use: pnpm build:mobile:ios or pnpm build:mobile:android'",
    "build:mobile:ios": "pnpm --filter @nvlp/mobile build:ios",
    "build:mobile:android": "pnpm --filter @nvlp/mobile build:android",
    "build:watch": "concurrently -n 'types,client' -c 'blue,yellow' 'pnpm --filter @nvlp/types dev' 'pnpm --filter @nvlp/client dev'",
    "test": "pnpm test:packages && pnpm test:apps",
    "test:all": "pnpm test:packages && pnpm test:apps",
    "test:packages": "pnpm test:types && pnpm test:client",
    "test:apps": "pnpm test:mobile && pnpm test:api",
    "test:types": "pnpm --filter @nvlp/types test",
    "test:client": "pnpm --filter @nvlp/client test",
    "test:mobile": "pnpm --filter @nvlp/mobile test || echo '⚠️  Mobile tests have React Native Jest compatibility issues'",
    "test:api": "pnpm --filter @nvlp/api test || echo '⚠️  API tests require Deno runtime'",
    "test:watch": "concurrently -n 'client,mobile' -c 'yellow,magenta' 'pnpm --filter @nvlp/client test:watch' 'pnpm --filter @nvlp/mobile test --watch'",
    "test:coverage": "echo 'Coverage available via: pnpm --filter @nvlp/client test:coverage (requires @vitest/coverage setup)'",
    "test:script": "./scripts/test-all.sh",
    "lint": "pnpm run -r lint",
    "lint:fix": "pnpm run -r lint:fix",
    "format": "pnpm run -r format",
    "format:check": "pnpm run -r format:check",
    "clean": "pnpm run -r clean && rm -rf node_modules",
    "clean:all": "pnpm run clean && rm -rf apps/*/node_modules packages/*/node_modules",
    "typecheck": "pnpm run -r typecheck",
    "install:all": "pnpm install",
    "update:deps": "pnpm update -r",
    "verify": "pnpm run build && pnpm run test && pnpm run lint",
    "deploy:api": "pnpm --filter @nvlp/api deploy",
    "deploy:api:auth": "pnpm --filter @nvlp/api deploy:auth",
    "deploy:api:dashboard": "pnpm --filter @nvlp/api deploy:dashboard",
    "deploy:api:transactions": "pnpm --filter @nvlp/api deploy:transactions",
    "deploy:api:reports": "pnpm --filter @nvlp/api deploy:reports",
    "db:reset": "pnpm --filter @nvlp/api db:reset",
    "db:migrate": "pnpm --filter @nvlp/api db:migrate",
    "db:types": "pnpm --filter @nvlp/api db:types",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish",
    "prepare": "pnpm run build:packages"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.13.1"
}